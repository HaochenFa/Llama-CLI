{
  "name": "llamacli",
  "version": "0.0.1",
  "description": "Your AI copilot in the terminal.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "llama-cli": "dist/index.js"
  },
  "scripts": {
    "start": "node .",
    "dev": "node --watch ./dist/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=esm --external:./node_modules/* --banner:js=\"#!/usr/bin/env node\"",
    "build:watch": "npm run build -- --watch",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "keywords": [
    "cli",
    "ai",
    "llm",
    "developer-tools"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ajv": "^8.17.1",
    "axios": "^1.7.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.23",
    "marked": "^11.2.0",
    "marked-terminal": "^6.2.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.4",
    "@types/ajv": "^0.0.5",
    "@types/commander": "^2.12.0",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "esbuild": "^0.21.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "jest": "^30.0.4",
    "ts-jest": "^29.4.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.35.0"
  }
}
